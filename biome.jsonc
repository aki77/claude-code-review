{
  "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": ["**", "!**/dist"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "correctness": {
        "useImportExtensions": {
          "level": "error",
          "options": {
            "extensionMappings": {
              "ts": "ts"
            }
          }
        }
      },
      "style": {
        // tsconfig の noUncheckedIndexedAccess により、配列/Map アクセス後の
        // 非nullアサーションは境界確認済みであることを示す正当な書き方として
        // 多用されている（125箇所）。recommended から除外する。
        "noNonNullAssertion": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
