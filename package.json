{
  "name": "@aki77/claude-code-review",
  "version": "0.7.0",
  "type": "module",
  "engines": {
    "node": ">=24.2"
  },
  "packageManager": "pnpm@10.33.4",
  "bin": {
    "code-review": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aki77/claude-code-review.git"
  },
  "homepage": "https://github.com/aki77/claude-code-review",
  "bugs": {
    "url": "https://github.com/aki77/claude-code-review/issues"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "node src/cli.ts",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome check --write .",
    "prepare": "git config --local core.hooksPath .githooks || echo 'Can not set git hooks'",
    "prepublishOnly": "pnpm build"
  },
  "lint-staged": {
    "*.{ts,json,jsonc}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.207",
    "ora": "^9.4.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@types/node": "^24.1.0",
    "lint-staged": "^17.0.8",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
